apiVersion: v1
kind: Service
metadata:
  name: kbs
  namespace: coco-tenant
  annotations:
    networking.gke.io/load-balancer-type: "Internal"
spec:
  type: LoadBalancer
  loadBalancerIP: "${kbs_ip}"
  selector:
    app: kbs
  ports:
    - name: kbs
      port: 8080
      targetPort: 8080
      protocol: TCP
